# Gemini API Key (server-side only, used by Vercel serverless functions)
GEMINI_API_KEY="your-gemini-api-key"

# Supabase (client-side, VITE_ prefix exposes to browser)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Supabase Service Role Key (server-side only, used by Vercel serverless functions)
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
